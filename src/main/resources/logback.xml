<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- We embed the original ':'-separated tag inside the message via Logging.emit so
                 the %logger{0} field would just duplicate it. Keep timestamp + level + msg only. -->
            <pattern>%d{HH:mm:ss.SSS} %-5level %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

    <logger name="🐙" level="DEBUG"/>
</configuration>
